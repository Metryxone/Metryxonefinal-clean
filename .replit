modules = ["nodejs-20", "web", "python-3.11", "postgresql-16"]
[nix]
channel = "stable-25_05"
packages = ["glibcLocales"]

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "build"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Upload Service"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && FF_CAREER_GRAPH=1 FF_RUNTIME_INTELLIGENCE_ACTIVATION=1 FF_RUNTIME_INTELLIGENCE_PIPELINE=1 FF_WC3_STAGE=1 FF_WC3_OUTCOME=1 FF_WC3_JOURNEY=1 FF_WC3_PERSONALIZATION=1 FF_WC3_LONGITUDINAL=1 FF_DECISION_ORCHESTRATOR=1 FF_JOURNEY_GROWTH_PLAN_BRIDGE=1 FF_DECISION_MENTOR_BRIDGE=1 FF_COMMERCIAL_ACTIVATION=1 FF_COMMERCIAL_ENTITLEMENT_ENFORCEMENT=1 FF_DECISION_PERSISTENCE=1 FF_BEHAVIOUR_NAMESPACE_ALIGNMENT=1 FF_USER_INTELLIGENCE_FOUNDATION=1 FF_TREND_INTELLIGENCE=1 FF_BEHAVIOUR_TREND_INTELLIGENCE=1 FF_MEMORY_INTELLIGENCE=1 FF_LEARNING_INTELLIGENCE=1 FF_FUTURE_READINESS=1 FF_CAREER_PASSPORT=1 FF_REPORT_FACTORY=1 FF_ENTERPRISE_ANALYTICS=1 FF_AI_GOVERNANCE=1 FF_COMPETENCY_INTELLIGENCE=1 FF_FORECAST_INTELLIGENCE=1 FF_EIOS_WORLD_CLASS_VERIFIED_V2=1 FF_GOVERNANCE_RBAC_V2=1 FF_COMPETENCY_FRAMEWORK_INTELLIGENCE=1 FF_COMPETENCY_RUNTIME=1 FF_COMPETENCY_EI=1 FF_CAREER_READINESS=1 FF_CAREER_GAP=1 FF_CAREER_ROADMAP=1 npm run dev:server"
waitForPort = 8080

[[workflows.workflow]]
name = "build"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npx vite build"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "Upload Service"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend-main && uv run --project /home/runner/workspace uvicorn app.main:app --host 0.0.0.0 --port 8000"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8080
externalPort = 8080

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd backend && NODE_ENV=production npx tsx index.ts"]
build = ["bash", "-c", "cd frontend && npm run build && rm -rf ../backend/public && mkdir -p ../backend/public && cp -r dist/. ../backend/public/"]

[userenv]

[userenv.production]
APP_URL = "https://metryx.one"

[userenv.shared]
VITE_FIREBASE_AUTH_DOMAIN = "metryxone-ai-a3431.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID = "metryxone-ai-a3431"
VITE_FIREBASE_STORAGE_BUCKET = "metryxone-ai-a3431.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID = "652730117933"
VITE_FIREBASE_MEASUREMENT_ID = "G-EQBJNCN5W6"
