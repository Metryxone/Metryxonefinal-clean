modules = ["nodejs-20", "web", "python-3.11", "postgresql-16"]
[nix]
channel = "stable-25_05"
packages = ["glibcLocales"]

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "build"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Upload Service"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "live-avatar-billing-cap"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "live-avatar-degradation"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "isolation"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "voice-screening-degradation"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "privacy"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && FF_ADAPTIVE_INTELLIGENCE_FOUNDATION=1 FF_EMPLOYER_COMPETENCY_HIRING=1 FF_CAREER_INTELLIGENCE=1 FF_CAREER_INTELLIGENCE_ACTIVATION=1 FF_CAREER_GRAPH=1 FF_RUNTIME_INTELLIGENCE_ACTIVATION=1 FF_RUNTIME_INTELLIGENCE_PIPELINE=1 FF_WC3_STAGE=1 FF_WC3_OUTCOME=1 FF_WC3_JOURNEY=1 FF_WC3_PERSONALIZATION=1 FF_WC3_LONGITUDINAL=1 FF_DECISION_ORCHESTRATOR=1 FF_JOURNEY_GROWTH_PLAN_BRIDGE=1 FF_DECISION_MENTOR_BRIDGE=1 FF_COMMERCIAL_ACTIVATION=1 FF_COMMERCIAL_ENTITLEMENT_ENFORCEMENT=1 FF_DECISION_PERSISTENCE=1 FF_BEHAVIOUR_NAMESPACE_ALIGNMENT=1 FF_USER_INTELLIGENCE_FOUNDATION=1 FF_TREND_INTELLIGENCE=1 FF_BEHAVIOUR_TREND_INTELLIGENCE=1 FF_MEMORY_INTELLIGENCE=1 FF_LEARNING_INTELLIGENCE=1 FF_FUTURE_READINESS=1 FF_CAREER_PASSPORT=1 FF_REPORT_FACTORY=1 FF_ENTERPRISE_ANALYTICS=1 FF_AI_GOVERNANCE=1 FF_COMPETENCY_INTELLIGENCE=1 FF_FORECAST_INTELLIGENCE=1 FF_EIOS_WORLD_CLASS_VERIFIED_V2=1 FF_GOVERNANCE_RBAC_V2=1 FF_COMPETENCY_FRAMEWORK_INTELLIGENCE=1 FF_COMPETENCY_RUNTIME=1 FF_COMPETENCY_EI=1 FF_CAREER_READINESS=1 FF_CAREER_GAP=1 FF_CAREER_MATCH=1 FF_CAREER_ROADMAP=1 FF_CAREER_DEVELOPMENT=1 FF_CAREER_RECOMMENDATION=1 FF_CAREER_SIMULATION=1 FF_CAREER_PASSPORT_FOUNDATION=1 FF_CAREER_SIGNAL=1 FF_CAREER_PROGRESSION=1 FF_CAREER_VALIDATION=1 FF_EMPLOYER_DASHBOARDS=1 FF_JOB_POSTING_ENGINE=1 FF_HIRING_ASSESSMENT=1 FF_TALENT_MATCHING=1 FF_INTERVIEW_INTELLIGENCE=1 FF_HIRING_INTELLIGENCE=1 FF_OUTCOME_INTELLIGENCE_ACTIVATION=1 FF_LIVE_EMPLOYER_ECOSYSTEM=1 FF_ROLE_DNA_GOVERNANCE=1 FF_ONET_CROSSWALK_GOVERNANCE=1 FF_QUESTION_FACTORY=1 FF_ADAPTIVE_DIFFICULTY_ACTIVATION=1 FF_ECOSYSTEM_ACTIVATION=1 npm run dev:server"
waitForPort = 8080

[[workflows.workflow]]
name = "build"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npx vite build"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "Upload Service"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend-main && uv run --project /home/runner/workspace uvicorn app.main:app --host 0.0.0.0 --port 8000"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "live-avatar-billing-cap"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && npx tsx scripts/task223-live-avatar-billing-cap.ts"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "live-avatar-degradation"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && npx tsx tests/live-avatar-degradation.test.ts"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "isolation"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && npm run test:isolation"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "voice-screening-degradation"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && npx tsx tests/voice-screening-degradation.test.ts"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "privacy"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && npx tsx scripts/privacy-e2e-suite.ts"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8091
externalPort = 3001

[[ports]]
localPort = 23636
externalPort = 3002

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd backend && NODE_ENV=production npx tsx index.ts"]
build = ["bash", "-c", "cd frontend && npm run build && rm -rf ../backend/public && mkdir -p ../backend/public && cp -r dist/. ../backend/public/"]

[userenv]

[userenv.production]
APP_URL = "https://metryx.one"
FF_PLATFORM_LIFECYCLE_FOUNDATION = "1"

[userenv.shared]
VITE_FIREBASE_AUTH_DOMAIN = "metryxone-ai-a3431.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID = "metryxone-ai-a3431"
VITE_FIREBASE_STORAGE_BUCKET = "metryxone-ai-a3431.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID = "652730117933"
VITE_FIREBASE_MEASUREMENT_ID = "G-EQBJNCN5W6"

[userenv.development]
FF_ONTOLOGY_HIERARCHY_V2 = "1"
FF_ROLE_AUTO_RESOLUTION = "1"
FF_PLATFORM_INTELLIGENCE_CONSOLE = "1"
FF_COMMAND_CENTER = "1"
FF_CAREER_DISCOVERY = "true"
FF_CAMPUS_PLACEMENT = "1"
FF_VOICE_SCREENING = "1"
FF_AVATAR_INTERVIEW = "1"
FF_LIVE_AVATAR_INTERVIEW = "1"
FF_LEARNING_PASSPORT_LOOP = "1"
FF_LAUNCH_CERTIFICATION = "1"
FF_CAREER_LAUNCHPAD = "1"
FF_STUDENT_CAREER_BUILDER = "1"
FF_EMPLOYABILITY_STUDIO = "1"
FF_INSTITUTIONAL_INTELLIGENCE = "1"
FF_LAUNCHPAD_DASHBOARD = "1"
FF_PLATFORM_LIFECYCLE_FOUNDATION = "1"
