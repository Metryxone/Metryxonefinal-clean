modules = ["nodejs-20", "web", "python-3.11", "postgresql-16"]
[nix]
channel = "stable-25_05"
packages = ["glibcLocales"]

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "build"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Upload Service"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test-referral-deal-value"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "referral-deal-value-writepath"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "referral-deal-value-repair"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && npm run dev:server"
waitForPort = 8080

[[workflows.workflow]]
name = "build"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npx vite build"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "Upload Service"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend-main && uv run --project /home/runner/workspace uvicorn app.main:app --host 0.0.0.0 --port 8000"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "test-referral-deal-value"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && npx tsx --test tests/partner-ecosystem-referral-deal-value.test.ts"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "referral-deal-value-writepath"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && npx tsx scripts/smoke-referral-deal-value-writepath.ts"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "referral-deal-value-repair"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && npx tsx scripts/smoke-referral-deal-value-repair.ts"

[workflows.workflow.metadata]
isValidation = true

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8100
externalPort = 3002

[[ports]]
localPort = 8101
externalPort = 4200

[[ports]]
localPort = 8102
externalPort = 3003

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd backend && NODE_ENV=production npx tsx index.ts"]
build = ["bash", "-c", "cd frontend && npm run build && rm -rf ../backend/public && mkdir -p ../backend/public && cp -r dist/. ../backend/public/"]

[userenv]

[userenv.production]
APP_URL = "https://metryx.one"

[userenv.shared]
VITE_FIREBASE_AUTH_DOMAIN = "metryxone-ai-a3431.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID = "metryxone-ai-a3431"
VITE_FIREBASE_STORAGE_BUCKET = "metryxone-ai-a3431.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID = "652730117933"
VITE_FIREBASE_MEASUREMENT_ID = "G-EQBJNCN5W6"

[userenv.development]
FF_ONTOLOGY_HIERARCHY_V2 = "1"
