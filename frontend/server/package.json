{
  "name": "metryx-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:introspect": "drizzle-kit introspect",
    "test:chat": "node --test src/__tests__/chat-sensitive.test.mjs",
    "test:chat-conciseness": "node --test src/__tests__/chat-conciseness.test.mjs",
    "test:chat-language": "node --test src/__tests__/chat-language.test.mjs",
    "test:conciseness-bullet": "node --test src/__tests__/conciseness-bullet.test.mjs",
    "test:conciseness-unit": "node --import tsx/esm --test src/__tests__/conciseness-filter.unit.test.ts",
    "test:db-smoke": "node --import tsx/esm --test src/__tests__/db-tables-smoke.test.ts",
    "test:chat-i18n": "node --test src/__tests__/chat-i18n.test.mjs",
    "test:chat-i18n-initial": "node --test src/__tests__/chat-i18n-initial-concerns.test.mjs",
    "test:chat-prefs-db": "node --test src/__tests__/chat-conciseness-db-pref.test.mjs",
    "test:chat-video": "node --import tsx/esm --test src/__tests__/chat-video-integration.test.ts",
    "test:chat-video-auth": "node --import tsx/esm --test src/__tests__/chat-video-integration-auth.test.ts",
    "test:school-coaching-lang": "node --test src/__tests__/chat-school-coaching-lang.test.mjs",
    "test:all": "node --import tsx/esm scripts/lint-migrations.ts && node --import tsx/esm --test src/__tests__/conciseness-filter.unit.test.ts src/__tests__/db-tables-smoke.test.ts src/__tests__/chat-video-integration.test.ts src/__tests__/chat-video-integration-auth.test.ts src/__tests__/video-selector.unit.test.ts src/__tests__/extract-table-names.test.ts && node --test src/__tests__/chat-school-coaching-lang.test.mjs",
    "lint:migrations": "node --import tsx/esm scripts/lint-migrations.ts"
  },
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^7.0.11",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.0",
    "dotenv": "^16.6.1",
    "drizzle-orm": "0.45.2",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.12.0",
    "mongoose": "^9.3.1",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.1",
    "openai": "^6.32.0",
    "p-limit": "^7.3.0",
    "p-retry": "^7.1.1",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "pg": "^8.11.3",
    "razorpay": "^2.9.6",
    "resend": "^3.2.0",
    "socket.io": "4.8.3",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.5",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "0.31.10",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
